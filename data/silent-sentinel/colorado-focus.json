        "lat": "39.7392",
        "lon": "-104.9903",
        "zoom": "8.5",
        "view": "colorado",
        "timeRange": "7d",
        "layers": "conflicts,hotspots,sanctions,weather,outages,natural",
        "silentSentinel": "1"
      },
      "local_url": "http://localhost:3000/dashboard?lat=39.7392&lon=-104.9903&zoom=8.5&view=colorado&timeRange=7d&layers=conflicts%2Chotspots%2Csanctions%2Cweather%2Coutages%2Cnatural&silentSentinel=1"
    },
    "denver-metro": {
      "path": "/dashboard",
      "query": {
        "lat": "39.7392",
        "lon": "-104.9903",
