{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "silent-sentinel-colorado-focus",
  "version": "0.1.0",
  "description": "Colorado focus for Silent Sentinel × World Monitor. Highest priority: Denver metro. Professional/public government activity only.",
  "ethics": {
    "scope": "professional_public_only",
    "forbidden": [
      "personal_addresses",
      "family",
      "health",
      "private_social",
      "non_public_location",
      "surveillance_of_private_life"
    ],
    "allowed": [
      "official_title_office",
      "public_calendars",
      "open_meetings",
      "voting_and_legislation",
      "official_press",
      "published_official_travel",
      "campaign_finance_filings",
      "contracts_and_budgets",
      "cora_public_records"
    ],
    "human_in_loop_required": true
  },
